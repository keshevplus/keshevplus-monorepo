# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
# Example (Neon): postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ── Session ───────────────────────────────────────────────────────────────────
# Secret used to sign session cookies — use a long, random string in production
SESSION_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# SMTP configuration for sending contact form notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_RECIPIENT_EMAIL=

# ── AI Integrations ──────────────────────────────────────────────────────────
# Provided by Replit AI Integrations — set these in your Vercel environment
# if you want the AI chat / Gemini features to work
AI_INTEGRATIONS_GEMINI_API_KEY=
AI_INTEGRATIONS_GEMINI_BASE_URL=
OPENAI_API_KEY=

# ── WhatsApp (optional) ───────────────────────────────────────────────────────
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
